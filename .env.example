# Server
GAME_SERVICE_PORT=8081

# Database (PostgreSQL on port 5432)
GAME_DB_URL=jdbc:postgresql://localhost:5432/game_db
GAME_DB_USERNAME=postgres
GAME_DB_PASSWORD=your-password-here

# Hibernate DDL mode. Default in application.yml is `validate` (prod-safe — service refuses
# to start on schema mismatch). Local dev typically wants `update` so Hibernate auto-creates
# new entity columns/tables without a manual ALTER step. NEVER set to `update` in production
# — silent schema mutation on startup is a security/correctness hazard. When versioned
# migrations land, this stays `validate` everywhere and migrations own all DDL.
DDL_AUTO=update

# Keycloak
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/game-cellar

# IGDB / Twitch API — required, get from dev.twitch.tv
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# IGDB optional overrides
IGDB_API_BASE_URL=https://api.igdb.com/v4
IGDB_CONNECT_TIMEOUT=2000
IGDB_READ_TIMEOUT=10000
IGDB_WORKER_ENABLED=true
IGDB_WORKER_DISCOVERY_LIMIT=500
IGDB_WORKER_DISCOVERY_PAGES=100
IGDB_WORKER_NEW_RELEASES_PAGES=10
IGDB_WORKER_CRON=0 30 3 * * *
IGDB_WORKER_RATE_LIMIT_DELAY_MS=250
